# Rename this file to `secrets.toml` and fill in your keys
# On Streamlit Cloud, paste these values into the "Secrets" section of your app settings

# Brevo — REQUIRED for email alerts
# Get this from: https://app.brevo.com/settings/keys/api
BREVO_API_KEY = "xkeysib-REPLACE-WITH-YOUR-KEY"

# Claude API — OPTIONAL (app works without it using rule-based fallback)
# Get this from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY = "sk-ant-REPLACE-WITH-YOUR-KEY"
